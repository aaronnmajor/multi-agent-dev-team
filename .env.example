# --- Required: LLM access ---
HELICONE_BASE_URL=https://openrouter.helicone.ai/api/v1
OPENROUTER_API_KEY=your-openrouter-key-here
HELICONE_API_KEY=your-helicone-key-here

# --- Optional: per-agent model overrides (must exist in MODEL_PRICES) ---
# MODEL_PM=gpt-4o
# MODEL_CODER=gpt-4o-mini
# MODEL_QA=gpt-4o-mini

# --- Optional: feature toggles ---
# CODER_SELF_REFLECTION=true     # Reflexion-style critique pass (default: enabled)
# PM_DEBATE_MODE=true            # Innovation #2: PM debate / consensus layer (default: disabled)

# --- Optional: persistent Chroma (auto-set by docker-compose) ---
# CHROMA_HOST=chroma
# CHROMA_PORT=8000

# --- Optional: LangSmith distributed tracing ---
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=ls__your-key-here
# LANGCHAIN_PROJECT=multi-agent-dev-team
